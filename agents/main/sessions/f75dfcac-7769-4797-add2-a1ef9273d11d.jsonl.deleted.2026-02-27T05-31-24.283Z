r_store_config,\n            history_db_path=\"/Users/hope/.openclaw/mem0/data/sqlite/history.db\"\n        )\n        \n        # Initialize Mem0\n        memory = Memory.from_config(memory_config)\n        print(\"✅ Mem0 initialized successfully!\")\n        \n        # Test adding memory\n        test_messages = [\n            {\"role\": \"user\", \"content\": \"This is a test memory for Qwen integration\"},\n            {\"role\": \"assistant\", \"content\": \"Test memory stored successfully\"}\n        ]\n        \n        print(\"🔄 Adding test memory...\")\n        memory.add(test_messages, user_id=\"worldhello321\")\n        print(\"✅ Test memory added successfully!\")\n        \n        # Test searching memory\n        print(\"🔍 Searching for test memory...\")\n        results = memory.search(\"test memory\", user_id=\"worldhello321\")\n        print(f\"✅ Found {len(results['results'])} memories!\")\n        \n        if results['results']:\n            print(f\"   Memory: {results['results'][0]['memory']}\")\n        \n        print(\"\\n🎉 Mem0 integration is working perfectly!\")\n        print(\"💡 Your intelligent memory system is ready to use!\")\n        \n    except Exception as e:\n        print(f\"❌ Error: {e}\")\n        print(\"⚠️  Mem0 integration needs attention\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":140120,"output":734,"cacheRead":0,"cacheWrite":0,"totalTokens":140854,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772089126925}}
