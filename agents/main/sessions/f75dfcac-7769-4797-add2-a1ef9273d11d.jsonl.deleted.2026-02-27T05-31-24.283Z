{"type":"message","id":"0dbac83e","parentId":"2193c1f7","timestamp":"2026-02-26T06:30:50.410Z","message":{"role":"assistant","content":[{"type":"text","text":"让我更新测试脚本：\n\n"},{"type":"toolCall","id":"call_b0b62b06a543478c98517a97","name":"write","arguments":{"path":"/Users/hope/.openclaw/mem0/test_mem0.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest Mem0 integration with Qwen API key\n\"\"\"\n\nimport os\nimport sys\n\n# Load environment variables\nenv_file = \"/Users/hope/.openclaw/mem0/.env\"\nif os.path.exists(env_file):\n    with open(env_file, 'r') as f:\n        for line in f:\n            if line.strip() and not line.startswith('#'):\n                key, value = line.strip().split('=', 1)\n                os.environ[key] = value\n\nprint(\"✅ Mem0 environment configured successfully!\")\nprint(f\"   API Key: {os.environ.get('OPENAI_API_KEY', 'Not set')}\")\nprint(f\"   Base URL: {os.environ.get('OPENAI_BASE_URL', 'Not set')}\")\nprint(f\"   Data path: /Users/hope/.openclaw/mem0/data/\")\n\n# Test Mem0 with correct Qwen configuration\ntry:\n    from mem0 import Memory\n    from mem0.configs.base import MemoryConfig\n    from mem0.llms.configs import LlmConfig\n    from mem0.embeddings.configs import EmbedderConfig\n    from mem0.vector_stores.configs import VectorStoreConfig\n    \n    # Create Qwen-compatible configuration\n    llm_config = LlmConfig(\n        provider=\"openai\",\n        config={\n            \"model\": \"qwen3-max-2026-01-23\",\n            \"api_key\": os.environ.get(\"OPENAI_API_KEY\"),\n            \"base_url\": os.environ.get(\"OPENAI_BASE_URL\"),\n            \"temperature\": 0.0\n        }\n    )\n    \n    embedder_config = EmbedderConfig(\n        provider=\"openai\",\n        config={\n            \"model\": \"text-embedding-3-small\",\n            \"api_key\": os.environ.get(\"OPENAI_API_KEY\"),\n            \"base_url\": os.environ.get(\"OPENAI_BASE_URL\")\n        }\n    )\n    \n    vector_store_config = VectorStoreConfig(\n        provider=\"qdrant\",\n        config={\n            \"path\": \"/Users/hope/.openclaw/mem0/data/qdrant\",\n            \"collection_name\": \"mem0_memories\"\n        }\n    )\n    \n    memory_config = MemoryConfig(\n        llm=llm_config,\n        embedder=embedder_config,\n        vector_store=vector_store_config,\n        history_db_path=\"/Users/hope/.openclaw/mem0/data/sqlite/history.db\"\n    )\n    \n    print(\"🚀 Testing Mem0 with Qwen API key...\")\n    print(\"=\" * 50)\n    \n    # Initialize Mem0\n    memory = Memory.from_config(memory_config)\n    print(\"✅ Mem0 initialized successfully!\")\n    \n    # Test adding memory\n    print(\"🔄 Adding test memory...\")\n    test_messages = [\n        {\"role\": \"user\", \"content\": \"This is a test memory for Mem0 integration\"},\n        {\"role\": \"assistant\", \"content\": \"Test memory stored successfully\"}\n    ]\n    \n    memory.add(test_messages, user_id=\"test_user\")\n    print(\"✅ Test memory added successfully!\")\n    \n    # Test searching memory\n    print(\"🔍 Searching test memory...\")\n    results = memory.search(\"test memory\", user_id=\"test_user\")\n    print(f\"✅ Found {len(results['results'])} memories!\")\n    \n    print(\"=\" * 50)\n    print(\"🎉 Mem0 integration working perfectly!\")\n    \nexcept Exception as e:\n    print(f\"❌ Error: {e}\")\n    print(\"=\" * 50)\n    print(\"⚠️  Mem0 integration needs attention\")\n    sys.exit(1)"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":128009,"output":791,"cacheRead":0,"cacheWrite":0,"totalTokens":128800,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772087406949}}
