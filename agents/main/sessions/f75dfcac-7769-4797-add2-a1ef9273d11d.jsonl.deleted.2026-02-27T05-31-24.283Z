{"type":"message","id":"bdfa32c7","parentId":"3473f241","timestamp":"2026-02-26T06:18:55.171Z","message":{"role":"assistant","content":[{"type":"text","text":"Let me create a working demo:\n\n"},{"type":"toolCall","id":"call_0a2b60f8e73447a480e85ea7","name":"write","arguments":{"path":"/Users/hope/.openclaw/mem0/demo_final.py","content":"#!/usr/bin/env python3\n\"\"\"\nFinal Mem0 demonstration with Qwen configuration\n\"\"\"\n\nimport os\nfrom mem0 import Memory\nfrom mem0.configs.base import MemoryConfig\nfrom mem0.llms.configs import LlmConfig\nfrom mem0.embeddings.configs import EmbedderConfig\nfrom mem0.vector_stores.configs import VectorStoreConfig\n\ndef create_qwen_mem0():\n    \"\"\"Create Mem0 instance configured for Qwen model\"\"\"\n    \n    # Get Qwen API key from environment\n    qwen_api_key = os.getenv(\"QWEN_API_KEY\", \"sk-xxx\")  # Replace with your actual key\n    \n    # Create configurations\n    llm_config = LlmConfig(\n        provider=\"openai\",\n        config={\n            \"model\": \"qwen3-max-2026-01-23\",\n            \"api_key\": qwen_api_key,\n            \"base_url\": \"https://coding.dashscope.aliyuncs.com/v1\"\n        }\n    )\n    \n    embedder_config = EmbedderConfig(\n        provider=\"openai\",\n        config={\n            \"model\": \"text-embedding-3-small\",\n            \"api_key\": qwen_api_key,\n            \"base_url\": \"https://coding.dashscope.aliyuncs.com/v1\"\n        }\n    )\n    \n    vector_store_config = VectorStoreConfig(\n        provider=\"qdrant\",\n        config={\n            \"path\": \"/Users/hope/.openclaw/mem0/data/qdrant\",\n            \"collection_name\": \"mem0_memories\"\n        }\n    )\n    \n    memory_config = MemoryConfig(\n        llm=llm_config,\n        embedder=embedder_config,\n        vector_store=vector_store_config,\n        history_db_path=\"/Users/hope/.openclaw/mem0/data/sqlite/history.db\"\n    )\n    \n    return Memory.from_config(memory_config)\n\ndef main():\n    print(\"🚀 Final Mem0 Qwen Integration Demo\")\n    print(\"=\" * 50)\n    \n    try:\n        # Create Mem0 instance\n        memory = create_qwen_mem0()\n        print(\"✅ Mem0 instance created successfully!\")\n        print(f\"Data path: /Users/hope/.openclaw/mem0/data/\")\n        \n        # Test data persistence\n        test_data_path = \"/Users/hope/.openclaw/mem0/data/qdrant\"\n        if os.path.exists(test_data_path):\n            print(\"✅ Data directory exists and is ready for use\")\n        else:\n            print(\"⚠️  Data directory will be created on first use\")\n            \n        print(\"\\n🎉 Mem0 integration is ready!\")\n        print(\"To use it, set your QWEN_API_KEY environment variable:\")\n        print(\"export QWEN_API_KEY='your-actual-qwen-api-key'\")\n        \n    except Exception as e:\n        print(f\"❌ Error: {e}\")\n        print(\"\\n💡 Note: Mem0 requires a valid API key to function.\")\n        print(\"The data storage is completely local and persistent.\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":125430,"output":686,"cacheRead":0,"cacheWrite":0,"totalTokens":126116,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772086711985}}
