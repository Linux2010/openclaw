{"type":"message","id":"957c51a4","parentId":"706d3409","timestamp":"2026-02-26T06:17:11.581Z","message":{"role":"assistant","content":[{"type":"text","text":"现在让我创建正确的演示脚本：\n\n"},{"type":"toolCall","id":"call_5c4a76099fd5457dae348aac","name":"write","arguments":{"path":"/Users/hope/.openclaw/mem0/demo_qwen.py","content":"#!/usr/bin/env python3\n\"\"\"\nMem0 with Qwen Demo\nUsing your existing OpenClaw Qwen configuration\n\"\"\"\n\nimport os\nimport sys\nsys.path.append('/Users/hope/.openclaw/mem0/config')\n\nfrom mem0 import Memory\nfrom mem0_qwen_config import get_mem0_config\n\ndef main():\n    print(\"🚀 Mem0 + Qwen 集成演示\")\n    print(\"=\" * 50)\n    \n    try:\n        # 使用您的Qwen配置\n        config = get_mem0_config()\n        memory = Memory.from_config(config)\n        \n        print(\"✅ Mem0初始化成功！\")\n        \n        # 测试添加记忆\n        messages = [\n            {\"role\": \"user\", \"content\": \"我是Hope，正在使用OpenClaw系统\"},\n            {\"role\": \"assistant\", \"content\": \"很高兴为您服务！\"}\n        ]\n        \n        print(\"\\n1. 添加用户身份记忆...\")\n        memory.add(messages, user_id=\"worldhello321\")\n        print(\"✅ 记忆添加成功！\")\n        \n        # 测试搜索\n        print(\"\\n2. 搜索相关记忆...\")\n        results = memory.search(\"用户身份\", user_id=\"worldhello321\")\n        print(f\"✅ 找到 {len(results.get('results', []))} 条相关记忆\")\n        \n        # 显示数据存储位置\n        print(f\"\\n3. 数据存储位置:\")\n        print(f\"   Qdrant: /Users/hope/.openclaw/mem0/data/qdrant\")\n        print(f\"   SQLite: /Users/hope/.openclaw/mem0/data/sqlite/history.db\")\n        \n        print(\"\\n🎉 Mem0 + Qwen 集成演示完成！\")\n        print(\"\\n💡 特性:\")\n        print(\"   • 完全本地数据存储\")\n        print(\"   • 使用您的Qwen模型\")\n        print(\"   • 跨代理记忆共享\")\n        print(\"   • 自动备份支持\")\n        \n    except Exception as e:\n        print(f\"❌ 演示失败: {e}\")\n        print(\"\\n可能的原因:\")\n        print(\"   • API密钥未正确设置\")\n        print(\"   • 网络连接问题\")\n        print(\"   • Qwen服务不可用\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":104409,"output":542,"cacheRead":0,"cacheWrite":0,"totalTokens":104951,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772086613145}}
