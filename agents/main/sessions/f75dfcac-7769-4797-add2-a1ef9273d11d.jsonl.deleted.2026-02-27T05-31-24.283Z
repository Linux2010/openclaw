{"type":"message","id":"c90425eb","parentId":"4ab4bc0f","timestamp":"2026-02-26T07:00:35.953Z","message":{"role":"assistant","content":[{"type":"text","text":"太好了！您的Qwen API是工作的！现在让我检查Mem0的配置。\n\n问题可能出在Mem0的模型名称上。让我尝试使用正确的模型名称。\n\n从您的API测试中，我看到模型名是 `qwen3-max-2026-01-23`。\n\n让我更新配置：\n\n"},{"type":"toolCall","id":"call_e676497b3dde4fe89a9ab5b6","name":"write","arguments":{"path":"/Users/hope/.openclaw/mem0/final_working_test.py","content":"#!/usr/bin/env python3\n\"\"\"\nFinal working test for Mem0 with Qwen API\n\"\"\"\n\nimport os\nfrom mem0 import Memory\n\ndef test_mem0_with_qwen():\n    \"\"\"Test Mem0 integration with Qwen API\"\"\"\n    \n    # Set environment variables from OpenClaw config\n    os.environ[\"OPENAI_API_KEY\"] = \"sk-sp-1f07658367b9409393e075f9f63490bf\"\n    os.environ[\"OPENAI_BASE_URL\"] = \"https://coding.dashscope.aliyuncs.com/v1\"\n    \n    print(\"✅ Environment variables set\")\n    print(f\"   API Key: {os.environ['OPENAI_API_KEY'][:12]}...\")\n    print(f\"   Base URL: {os.environ['OPENAI_BASE_URL']}\")\n    \n    # Create Mem0 configuration as a dictionary\n    config = {\n        \"llm\": {\n            \"provider\": \"openai\",\n            \"config\": {\n                \"model\": \"qwen3-max-2026-01-23\",\n                \"temperature\": 0.0,\n                \"api_key\": \"sk-sp-1f07658367b9409393e075f9f63490bf\",\n                \"base_url\": \"https://coding.dashscope.aliyuncs.com/v1\"\n            }\n        },\n        \"embedder\": {\n            \"provider\": \"openai\",\n            \"config\": {\n                \"model\": \"text-embedding-3-small\",\n                \"api_key\": \"sk-sp-1f07658367b9409393e075f9f63490bf\",\n                \"base_url\": \"https://coding.dashscope.aliyuncs.com/v1\"\n            }\n        },\n        \"vector_store\": {\n            \"provider\": \"qdrant\",\n            \"config\": {\n                \"path\": \"/Users/hope/.openclaw/mem0/data/qdrant\",\n                \"collection_name\": \"mem0_memories\"\n            }\n        },\n        \"history_db_path\": \"/Users/hope/.openclaw/mem0/data/sqlite/history.db\"\n    }\n    \n    try:\n        # Initialize Mem0 with configuration\n        memory = Memory.from_config(config)\n        print(\"✅ Mem0 initialized successfully!\")\n        \n        # Test adding memory\n        print(\"🔄 Adding test memory...\")\n        messages = [\n            {\"role\": \"user\", \"content\": \"I am testing Mem0 integration with Qwen.\"},\n            {\"role\": \"assistant\", \"content\": \"This is a test memory for Mem0 integration.\"}\n        ]\n        \n        result = memory.add(messages, user_id=\"test_user\")\n        print(f\"✅ Memory added successfully! Result: {result}\")\n        \n        # Test searching memory\n        print(\"🔍 Searching test memory...\")\n        search_result = memory.search(\"Mem0 integration test\", user_id=\"test_user\")\n        print(f\"✅ Search completed! Found {len(search_result.get('results', []))} memories\")\n        \n        return True\n        \n    except Exception as e:\n        print(f\"❌ Error: {e}\")\n        return False\n\nif __name__ == \"__main__\":\n    print(\"🚀 Final Working Test for Mem0 with Qwen\")\n    print(\"=\" * 60)\n    \n    success = test_mem0_with_qwen()\n    \n    if success:\n        print(\"🎉 Mem0 integration is working perfectly!\")\n    else:\n        print(\"⚠️  Mem0 integration needs attention\")"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":141075,"output":869,"cacheRead":0,"cacheWrite":0,"totalTokens":141944,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772089206596}}
