            }\n        },\n        \"history_db_path\": \"/Users/hope/.openclaw/mem0/data/sqlite/history.db\"\n    }\n    \n    print(\"🚀 Testing Mem0 with Qwen API key...\")\n    print(\"=\" * 50)\n    \n    # Initialize Mem0\n    memory = Memory.from_config(config)\n    print(\"✅ Mem0 initialized successfully!\")\n    \n    # Test adding memory\n    print(\"🔄 Adding test memory...\")\n    test_messages = [\n        {\"role\": \"user\", \"content\": \"This is a test memory for Mem0 integration\"},\n        {\"role\": \"assistant\", \"content\": \"Test memory stored successfully\"}\n    ]\n    \n    result = memory.add(test_messages, user_id=\"test_user\")\n    print(\"✅ Test memory added successfully!\")\n    \n    # Test searching memory\n    print(\"🔍 Searching test memory...\")\n    search_result = memory.search(\"test memory\", user_id=\"test_user\")\n    print(f\"✅ Found {len(search_result['results'])} memories!\")\n    \n    print(\"=\" * 50)\n    print(\"🎉 Mem0 integration successful!\")\n    print(\"💡 Your agents can now use intelligent memory!\")\n    \nexcept Exception as e:\n    print(\"❌ Error:\", str(e))\n    print(\"=\" * 50)\n    print(\"⚠️  Mem0 integration needs attention\")\n    sys.exit(1)"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":129905,"output":726,"cacheRead":0,"cacheWrite":0,"totalTokens":130631,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772087643747}}
