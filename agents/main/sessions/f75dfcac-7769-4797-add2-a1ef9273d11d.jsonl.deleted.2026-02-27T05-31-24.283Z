{"type":"message","id":"af64a0a3","parentId":"5cfae830","timestamp":"2026-02-26T05:40:06.849Z","message":{"role":"toolResult","toolCallId":"call_70d3f79d13264a83bf6e4455","toolName":"web_search","content":[{"type":"text","text":"{\n  \"query\": \"mem0 ai open source github installation without docker\",\n  \"provider\": \"brave\",\n  \"count\": 5,\n  \"tookMs\": 1001,\n  \"results\": [\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT>>>\\nSource: Web Search\\n---\\nGitHub - mem0ai/mem0: Universal memory layer for AI Agents\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT>>>\",\n      \"url\": \"https://github.com/mem0ai/mem0\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT>>>\\nSource: Web Search\\n---\\nUniversal memory layer for AI Agents. Contribute to mem0ai/mem0 development by creating an account on GitHub.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT>>>\",\n      \"siteName\": \"github.com\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT>>>\\nSource: Web Search\\n---\\nOverview - Mem0\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT>>>\",\n      \"url\": \"https://docs.mem0.ai/open-source/overview\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT>>>\\nSource: Web Search\\n---\\nSelf-host Mem0 with full control over your infrastructure and data\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT>>>\",\n      \"siteName\": \"docs.mem0.ai\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT>>>\\nSource: Web Search\\n---\\nGitHub - CaviraOSS/OpenMemory: Local persistent memory store for LLM applications including claude desktop, github copilot, codex, antigravity, etc.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT>>>\",\n      \"url\": \"https://github.com/CaviraOSS/OpenMemory\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT>>>\\nSource: Web Search\\n---\\nLocal persistent memory store for LLM applications including claude desktop, github copilot, codex, antigravity, etc. - CaviraOSS/OpenMemory\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT>>>\",\n 