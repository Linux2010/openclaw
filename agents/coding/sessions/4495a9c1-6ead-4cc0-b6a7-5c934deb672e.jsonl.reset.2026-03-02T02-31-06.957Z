{"type":"message","id":"f241b741","parentId":"33b4ff7c","timestamp":"2026-03-02T02:14:34.587Z","message":{"role":"assistant","content":[{"type":"text","text":"现在让我继续解决 **Issue #30441**。根据issue描述，我需要在消息输出路径中添加函数调用语法的清理过滤器。\n\n让我分析问题所在。从issue描述来看，问题是在Codex子代理输出中泄露了原始的函数调用语法（`assistant to=functions.*`）和幻觉的中文垃圾内容。\n\n根据代码分析，问题可能出现在 `pi-embedded-subscribe.handlers.messages.ts` 文件中的 `handleMessageUpdate` 和 `handleMessageEnd` 函数中。\n\n让我创建一个清理函数来过滤这些模式：\n\n"},{"type":"toolCall","id":"call_9cd74b4cf6d24359825f5c03","name":"write","arguments":{"path":"src/agents/pi-embedded-sanitization.ts","content":"/**\n * Sanitization utilities for cleaning up malformed model outputs.\n * \n * This module provides functions to remove known problematic patterns\n * from model outputs before they are delivered to users.\n */\n\n/**\n * Regular expression to match OpenAI function-call wire format leaks.\n * Matches patterns like: \"assistant to=functions.subagents.commentary\"\n */\nconst FUNCTION_CALL_LEAK_PATTERN = /assistant\\s+to=functions\\.\\S+/gi;\n\n/**\n * Regular expression to match Chinese gambling/spam tokens that appear\n * as hallucinated content in corrupted model outputs.\n * This is a defensive measure against known training data artifacts.\n */\nconst CHINESE_SPAM_PATTERN = /[\\u4e00-\\u9fff]+(彩票|北京赛车|大发|时时彩|娱乐城|赌博|博彩|赌球|赌马|百家乐|轮盘|骰子|21点|德州扑克|梭哈|牛牛|扎金花|斗地主|麻将|棋牌|游戏|娱乐|娱乐城|赌场|赌城|博彩公司|体育投注|电竞博彩|虚拟币|比特币|以太坊|狗狗币|莱特币|瑞波币|泰达币|USDT|USDC|BNB|ADA|DOT|LTC|BCH|XRP|DOGE|SHIB|UNI|MATIC|LINK|ATOM|XLM|ALGO|VET|FIL|THETA|TRX|EOS|NEO|DASH|ZEC|XMR|ETC|QTUM|ICX|ONT|ZIL|KSM|CAKE|AAVE|COMP|MKR|SNX|YFI|CRV|BAL|REN|KNC|BNT|OCEAN|MANA|ENJ|SAND|AXS|GALA|ILV|APE|GMT|STEPN|LOOKS|IMX|GODS|STARL|WAXP|HIVE|STEEM|BLUR|OP|ARB|STRK|INJ|SEI|TIA|RNDR|AKT|OSMO|EGLD|NEAR|FTM|ONE|AVAX|SOL|LUNA|UST|LUNC|KAVA|HBAR|FLOW|ICP|ROSE|CELO|MINA|ZETA|APT|SUI|TON|NOT|FET|AGIX|TAO|RNDR|AKT|OSMO|EGLD|NEAR|FTM|ONE|AVAX|SOL|LUNA|UST|LUNC|KAVA|HBAR|FLOW|ICP|ROSE|CELO|MINA|ZETA|APT|SUI|TON|NOT|FET|AGIX|TAO)/g;\n\n/**\n * Sanitize model output by removing known problematic patterns.\n * \n * @param text - The raw model output text\n * @returns Sanitized text with problematic patterns removed\n */\nexport function sanitizeModelOutput(text: string): string {\n  if (!text) {\n    return text;\n  }\n\n  // Remove function call wire format leaks\n  let cleaned = text.replace(FUNCTION_CALL_LEAK_PATTERN, '');\n\n  // Remove Chinese spam/gambling tokens\n  cleaned = cleaned.replace(CHINESE_SPAM_PATTERN, '');\n\n  // Remove any remaining standalone \"assistant\" tokens that might be left\n  cleaned = cleaned.replace(/\\bassistant\\b/gi, '');\n\n  // Clean up extra whitespace and special characters\n  cleaned = cleaned\n    .replace(/[#＋]+/g, '') // Remove hash and plus symbols used as separators\n    .replace(/\\s+/g, ' ')   // Normalize whitespace\n    .trim();\n\n  return cleaned;\n}\n\n/**\n * Check if text contains known problematic patterns that should be filtered.\n * \n * @param text - The text to check\n * @returns true if the text contains problematic patterns\n */\nexport function hasProblematicPatterns(text: string): boolean {\n  if (!text) {\n    return false;\n  }\n  \n  return FUNCTION_CALL_LEAK_PATTERN.test(text) || CHINESE_SPAM_PATTERN.test(text);\n}"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":109891,"output":1023,"cacheRead":0,"cacheWrite":0,"totalTokens":110914,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772417608716}}
