{"type":"message","id":"2ff36b10","parentId":"d0d5a283","timestamp":"2026-03-02T02:27:47.885Z","message":{"role":"assistant","content":[{"type":"text","text":"现在让我创建测试文件来验证修复：\n\n"},{"type":"toolCall","id":"call_b4347962fed947b8ad1ad968","name":"write","arguments":{"path":"src/agents/pi-embedded-sanitization.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { sanitizeFunctionCallLeaks } from \"./pi-embedded-sanitization.js\";\n\ndescribe(\"sanitizeFunctionCallLeaks\", () => {\n  it(\"should remove function call syntax patterns\", () => {\n    const input = `+#+#+#+#+#+assistant to=functions.subagents.commentary 体育彩票天天json\n{\"action\":\"list\",\"recentMinutes\":20} hag̃assistant to=functions.subagents.commentary\n北京赛车群json {\"action\":\"list\",\"recentMinutes\":120}期开奖结果\nassistant to=functions.subagents.commentary 大发分分彩json {\"action\":\"list\"}\nеиҭеиҳәеитassistant to=functions.sessions_list.commentary\n天天中彩票网json {\"kinds\":[\"subagent\"],\"limit\":20,\"activeMinutes\":180,\"messageLimit\":1}`;\n    \n    const result = sanitizeFunctionCallLeaks(input);\n    expect(result).toBe(\"\");\n  });\n\n  it(\"should handle mixed content with function calls\", () => {\n    const input = `Here is a normal message. assistant to=functions.subagents.commentary \n体育彩票天天json {\"action\":\"list\"} And more normal text.`;\n    \n    const result = sanitizeFunctionCallLeaks(input);\n    expect(result).toBe(\"Here is a normal message.  And more normal text.\");\n  });\n\n  it(\"should preserve normal text without function calls\", () => {\n    const input = \"This is a normal message with no function calls.\";\n    const result = sanitizeFunctionCallLeaks(input);\n    expect(result).toBe(input);\n  });\n\n  it(\"should handle empty input\", () => {\n    const result = sanitizeFunctionCallLeaks(\"\");\n    expect(result).toBe(\"\");\n  });\n\n  it(\"should handle only function call patterns\", () => {\n    const input = \"assistant to=functions.subagents.commentary 体育彩票天天json\";\n    const result = sanitizeFunctionCallLeaks(input);\n    expect(result).toBe(\"\");\n  });\n\n  it(\"should handle multiple consecutive function calls\", () => {\n    const input = `assistant to=functions.subagents.commentary test1\nassistant to=functions.subagents.commentary test2\nassistant to=functions.subagents.commentary test3`;\n    const result = sanitizeFunctionCallLeaks(input);\n    expect(result).toBe(\"\");\n  });\n});"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":118457,"output":523,"cacheRead":0,"cacheWrite":0,"totalTokens":118980,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772418449961}}
